{
  "name": "rtl-for-claude",
  "displayName": "RTL for Claude",
  "description": "Right-to-left text + the Vazirmatn font in the Claude Code chat — for Persian, Arabic, Urdu and every RTL language. Auto-applies and survives Claude updates.",
  "version": "1.0.1",
  "publisher": "mahdigh99",
  "author": "Mahdi Ghorbanian",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mahdigh99/rtl-for-claude.git"
  },
  "homepage": "https://github.com/mahdigh99/rtl-for-claude#readme",
  "bugs": {
    "url": "https://github.com/mahdigh99/rtl-for-claude/issues"
  },
  "galleryBanner": {
    "color": "#1f1f1f",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "rtl",
    "persian",
    "farsi",
    "arabic",
    "urdu",
    "hebrew",
    "claude",
    "bidi",
    "vazirmatn"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "scripts": {
    "vscode:uninstall": "node ./uninstall.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "rtlForClaude.toggle",
        "title": "Turn On / Off",
        "category": "RTL for Claude"
      },
      {
        "command": "rtlForClaude.toggleSidebar",
        "title": "Show / Hide Sidebar Panel",
        "category": "RTL for Claude"
      },
      {
        "command": "rtlForClaude.apply",
        "title": "Re-apply to the chat now",
        "category": "RTL for Claude"
      },
      {
        "command": "rtlForClaude.remove",
        "title": "Restore original chat (run before uninstalling)",
        "category": "RTL for Claude"
      },
      {
        "command": "rtlForClaude.openSettings",
        "title": "Open Settings",
        "category": "RTL for Claude"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rtlForClaude",
          "title": "RTL for Claude",
          "icon": "media/panel-icon.svg"
        }
      ]
    },
    "views": {
      "rtlForClaude": [
        {
          "type": "webview",
          "id": "rtlForClaude.panel",
          "name": "RTL for Claude",
          "when": "config.rtlForClaude.showInActivityBar"
        }
      ]
    },
    "configuration": {
      "title": "RTL for Claude",
      "properties": {
        "rtlForClaude.enabled": {
          "type": "boolean",
          "default": true,
          "order": 0,
          "markdownDescription": "Turn right-to-left support **on or off** in the Claude Code chat. (Reload the window after changing.)"
        },
        "rtlForClaude.autoApplyOnStartup": {
          "type": "boolean",
          "default": true,
          "order": 1,
          "markdownDescription": "Re-apply automatically on startup — needed because every Claude Code update overwrites the patch."
        },
        "rtlForClaude.showInActivityBar": {
          "type": "boolean",
          "default": true,
          "order": 10,
          "description": "Show the RTL for Claude panel (big icon) in the left Activity Bar."
        },
        "rtlForClaude.showStatusBar": {
          "type": "boolean",
          "default": true,
          "order": 11,
          "description": "Show the small RTL on/off item in the status bar."
        },
        "rtlForClaude.font.family": {
          "type": "string",
          "enum": [
            "Vazirmatn",
            "Sahel",
            "System default"
          ],
          "default": "Vazirmatn",
          "order": 2,
          "description": "Font used for right-to-left text."
        },
        "rtlForClaude.font.scale": {
          "type": "number",
          "default": 1,
          "minimum": 0.8,
          "maximum": 1.6,
          "order": 3,
          "description": "Size of RTL text relative to the editor default (1 = 100%)."
        },
        "rtlForClaude.font.lineHeight": {
          "type": "number",
          "default": 1.85,
          "minimum": 1.3,
          "maximum": 2.5,
          "order": 4,
          "description": "Line spacing for right-to-left text."
        },
        "rtlForClaude.detection.mode": {
          "type": "string",
          "enum": [
            "ratio",
            "first-strong"
          ],
          "enumDescriptions": [
            "Smart: a paragraph goes RTL once enough of its letters are RTL (best for text full of English terms).",
            "Use the first strong character, like the browser's native dir=\"auto\"."
          ],
          "default": "ratio",
          "order": 5,
          "description": "How the direction of each paragraph is decided."
        },
        "rtlForClaude.detection.threshold": {
          "type": "number",
          "default": 0.3,
          "minimum": 0.1,
          "maximum": 0.7,
          "order": 6,
          "markdownDescription": "Smart mode only: minimum share of RTL letters (0.1–0.7) for a paragraph to become RTL. Lower = flips more easily."
        },
        "rtlForClaude.applyToInput": {
          "type": "boolean",
          "default": true,
          "order": 7,
          "description": "Also flip the message box to RTL as you type."
        },
        "rtlForClaude.showMessageToggles": {
          "type": "boolean",
          "default": true,
          "order": 8,
          "description": "Show a small toggle on each message to override its direction by hand."
        },
        "rtlForClaude.keepCodeLeftToRight": {
          "type": "boolean",
          "default": true,
          "order": 9,
          "description": "Keep code blocks, diffs and terminals left-to-right."
        }
      }
    }
  }
}
